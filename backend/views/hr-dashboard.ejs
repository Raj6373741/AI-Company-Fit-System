<%
currentPage = 'dashboard';
%>

<!-- CSP Meta Tag - Allow CDN and inline scripts -->
<meta http-equiv="Content-Security-Policy" 
      content="default-src 'self'; 
               script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; 
               style-src 'self' 'unsafe-inline'; 
               img-src 'self' data:;">

<!-- Chart.js CDN - Using older version for better compatibility -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>

<!-- Success Message -->
<% if (typeof created !== 'undefined' && created === 'success') { %>
    <div class="alert success">✅ Job created successfully!</div>
<% } %>

<div class="dashboard-header">
    <h2>HR Dashboard</h2>
    <p class="text-secondary">Welcome back, HR! Here's your complete overview.</p>
</div>

<!-- Statistics Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-content">
            <span class="stat-label">Total Jobs</span>
            <span class="stat-value"><%= totalJobs || 0 %></span>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-content">
            <span class="stat-label">Total Candidates</span>
            <span class="stat-value"><%= totalCandidates || 0 %></span>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon">📝</div>
        <div class="stat-content">
            <span class="stat-label">Applications</span>
            <span class="stat-value"><%= totalApplications || 0 %></span>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon">🏆</div>
        <div class="stat-content">
            <span class="stat-label">Active Jobs</span>
            <span class="stat-value"><%= activeJobs || 0 %></span>
        </div>
    </div>
</div>

<!-- Create Job Card -->
<div class="card create-job-card">
    <h3>Create New Job</h3>
    <form method="POST" action="/hr/job/create" class="job-form">
        <div class="form-row">
            <div class="form-group">
                <label>Job Title</label>
                <input type="text" name="title" placeholder="e.g. Senior Developer" required>
            </div>
            <div class="form-group">
                <label>Min Experience (years)</label>
                <input type="number" name="minExperience" placeholder="e.g. 3" required>
            </div>
        </div>
        <div class="form-group">
            <label>Required Skills</label>
            <input type="text" name="skills" placeholder="JavaScript, React, Node.js" required>
            <small class="hint">Separate skills with commas</small>
        </div>
        <button type="submit" class="btn-primary">Create Job</button>
    </form>
</div>

<!-- Charts Section -->
<div class="charts-section">
    <div class="chart-row">
        <!-- Hiring Trends Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <h3>📈 Hiring Trends</h3>
                <div class="chart-filters" id="hiringFilters">
                    <button class="filter-btn active" onclick="updateHiringChart(12)">1Y</button>
                    <button class="filter-btn" onclick="updateHiringChart(6)">6M</button>
                    <button class="filter-btn" onclick="updateHiringChart(3)">3M</button>
                    <button class="filter-btn" onclick="updateHiringChart(1)">1M</button>
                </div>
            </div>
            <div class="chart-container">
                <canvas id="hiringChart"></canvas>
            </div>
        </div>
        
        <!-- Top Jobs Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <h3>🏆 Top Jobs by Applications</h3>
                <div class="chart-filters" id="topJobsFilters">
                    <button class="filter-btn active" onclick="updateTopJobsChart(5)">Top 5</button>
                    <button class="filter-btn" onclick="updateTopJobsChart(3)">Top 3</button>
                </div>
            </div>
            <div class="chart-container">
                <canvas id="topJobsChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Job Listings -->
<div class="job-listings">
    <h3>Current Job Openings</h3>
    
    <% if (jobs.length === 0) { %>
        <div class="empty-state">
            <p>No jobs created yet. Create your first job above.</p>
        </div>
    <% } else { %>
        <div class="job-grid">
            <% jobs.forEach(job => { %>
                <div class="job-card">
                    <div class="job-header">
                        <h4><%= job.title %></h4>
                        <span class="status-badge <%= job.status || 'open' %>">
                            <%= job.status || 'open' %>
                        </span>
                    </div>
                    
                    <div class="job-details">
                        <div class="detail-item">
                            <span class="detail-label">Experience:</span>
                            <span class="detail-value"><%= job.minExperience %> years</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Skills:</span>
                            <span class="detail-value">
                                <%= job.requiredSkills.slice(0,3).join(', ') %>
                                <% if (job.requiredSkills.length > 3) { %>...<% } %>
                            </span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Applications:</span>
                            <span class="detail-value highlight"><%= job.applicationCount || 0 %></span>
                        </div>
                    </div>
                    
                    <div class="job-actions">
                        <a href="/hr/job/<%= job._id %>/applicants" class="action-btn applicants">
                            View Applicants (<%= job.applicationCount || 0 %>)
                        </a>
                        <% if (job.status !== 'closed') { %>
                            <a href="/hr/job/<%= job._id %>/close" class="action-btn close" 
                               onclick="return confirm('Close this job?')">Close</a>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<style>
/* Dashboard Styles */
.dashboard-header { margin-bottom: 30px; }
.dashboard-header h2 { font-size: 1.8rem; font-weight: 600; color: #1d1d1f; margin-bottom: 8px; }
.text-secondary { color: #86868b; }

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: white;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #e5e5e5;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: all 0.2s;
}

.stat-card:hover { box-shadow: 0 5px 20px rgba(0,0,0,0.03); transform: translateY(-2px); }

.stat-icon {
    font-size: 2rem;
    background: #f5f5f7;
    width: 50px;
    height: 50px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-content { flex: 1; }
.stat-label { display: block; color: #86868b; font-size: 0.85rem; margin-bottom: 4px; }
.stat-value { display: block; font-size: 1.8rem; font-weight: 600; color: #1d1d1f; }

/* Create Job Card */
.card {
    background: white;
    border-radius: 24px;
    padding: 24px;
    border: 1px solid #e5e5e5;
    margin-bottom: 30px;
}

.create-job-card h3 { font-size: 1.2rem; font-weight: 600; color: #1d1d1f; margin-bottom: 20px; }
.job-form { max-width: 600px; }

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.form-group { margin-bottom: 20px; }
.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    color: #1d1d1f;
    font-size: 0.95rem;
}

.form-group input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #d2d2d7;
    border-radius: 12px;
    font-size: 0.95rem;
    transition: all 0.2s;
}

.form-group input:focus {
    outline: none;
    border-color: #1d1d1f;
    box-shadow: 0 0 0 3px rgba(0,0,0,0.02);
}

.hint { display: block; color: #86868b; font-size: 0.8rem; margin-top: 6px; }

.btn-primary {
    background: #1d1d1f;
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-primary:hover { background: #2d2d2f; }

/* Charts Section */
.charts-section { margin-bottom: 40px; }
.chart-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.chart-card {
    background: white;
    border-radius: 24px;
    padding: 24px;
    border: 1px solid #e5e5e5;
}

.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 15px;
}

.chart-header h3 { font-size: 1.1rem; font-weight: 600; color: #1d1d1f; margin: 0; }

.chart-filters {
    display: flex;
    gap: 8px;
}

.filter-btn {
    background: #f5f5f7;
    border: none;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #86868b;
    cursor: pointer;
    transition: all 0.2s;
}

.filter-btn:hover {
    background: #e5e5e5;
    color: #1d1d1f;
}

.filter-btn.active {
    background: #1d1d1f;
    color: white;
}

.chart-container {
    position: relative;
    height: 250px;
    width: 100%;
}

/* Job Listings */
.job-listings { margin-top: 40px; }
.job-listings h3 { font-size: 1.2rem; font-weight: 600; color: #1d1d1f; margin-bottom: 20px; }

.job-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 20px;
}

.job-card {
    background: white;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #e5e5e5;
    transition: all 0.2s;
}

.job-card:hover {
    box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    transform: translateY(-2px);
}

.job-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
}

.job-header h4 { font-size: 1.1rem; font-weight: 600; color: #1d1d1f; margin: 0; }

.status-badge {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
}

.status-badge.open { background: #e6f7e6; color: #0e6245; }
.status-badge.closed { background: #fee2e2; color: #991b1b; }

.job-details { margin-bottom: 20px; }
.detail-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 0.9rem;
    padding: 4px 0;
    border-bottom: 1px solid #f5f5f7;
}

.detail-label { color: #86868b; }
.detail-value { color: #1d1d1f; font-weight: 500; }
.detail-value.highlight { color: #10b981; font-weight: 600; }

.job-actions {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.action-btn {
    flex: 1;
    padding: 10px;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    text-align: center;
    transition: all 0.2s;
}

.action-btn.applicants { background: #1d1d1f; color: white; }
.action-btn.applicants:hover { background: #2d2d2f; }
.action-btn.close { background: #fee2e2; color: #991b1b; }
.action-btn.close:hover { background: #fecaca; }

.alert.success {
    background: #e6f7e6;
    color: #0e6245;
    padding: 16px;
    border-radius: 12px;
    margin-bottom: 20px;
    border-left: 4px solid #0e6245;
}

.empty-state {
    background: white;
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    color: #86868b;
    border: 1px dashed #d2d2d7;
}

/* Responsive */
@media (max-width: 768px) {
    .chart-row { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .chart-header { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
// ===== CHART DATA =====
const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const hiringData = [45, 52, 38, 65, 48, 72, 58, 63, 71, 55, 68, 74];

const topJobsData = [
    { title: 'Frontend Developer', count: 45 },
    { title: 'Backend Developer', count: 38 },
    { title: 'Full Stack Developer', count: 32 },
    { title: 'DevOps Engineer', count: 28 },
    { title: 'Data Scientist', count: 25 },
    { title: 'Mobile Developer', count: 22 },
    { title: 'UI/UX Designer', count: 18 }
];

// Chart instances
let hiringChart = null;
let topJobsChart = null;

// ===== INITIALIZE HIRING CHART =====
function initHiringChart(monthsCount = 12) {
    const ctx = document.getElementById('hiringChart').getContext('2d');
    
    // Get last N months
    const lastMonths = months.slice(-monthsCount);
    const lastData = hiringData.slice(-monthsCount);
    
    // Destroy existing chart if any
    if (hiringChart) {
        hiringChart.destroy();
    }
    
    hiringChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: lastMonths,
            datasets: [{
                label: 'Applications',
                data: lastData,
                borderColor: '#1d1d1f',
                backgroundColor: 'rgba(29, 29, 31, 0.1)',
                borderWidth: 2,
                tension: 0.3,
                fill: true,
                pointBackgroundColor: '#1d1d1f',
                pointBorderColor: 'white',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: { 
                    backgroundColor: 'white',
                    titleColor: '#1d1d1f',
                    bodyColor: '#1d1d1f',
                    borderColor: '#e5e5e5',
                    borderWidth: 1
                }
            },
            scales: {
                y: { 
                    beginAtZero: true,
                    grid: { color: '#f0f0f0' },
                    ticks: { color: '#86868b' }
                },
                x: { 
                    grid: { display: false },
                    ticks: { color: '#86868b' }
                }
            }
        }
    });
}

// ===== INITIALIZE TOP JOBS CHART =====
function initTopJobsChart(limit = 5) {
    const ctx = document.getElementById('topJobsChart').getContext('2d');
    
    // Sort and limit data
    const sortedData = [...topJobsData].sort((a, b) => b.count - a.count);
    const limitedData = sortedData.slice(0, limit);
    
    // Destroy existing chart if any
    if (topJobsChart) {
        topJobsChart.destroy();
    }
    
    topJobsChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: limitedData.map(j => j.title),
            datasets: [{
                label: 'Applications',
                data: limitedData.map(j => j.count),
                backgroundColor: '#1d1d1f',
                borderRadius: 8,
                barPercentage: 0.6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'white',
                    titleColor: '#1d1d1f',
                    bodyColor: '#1d1d1f',
                    borderColor: '#e5e5e5',
                    borderWidth: 1
                }
            },
            scales: {
                y: { 
                    beginAtZero: true,
                    grid: { color: '#f0f0f0' },
                    ticks: { color: '#86868b' }
                },
                x: { 
                    grid: { display: false },
                    ticks: { 
                        color: '#86868b',
                        maxRotation: 45,
                        minRotation: 45
                    }
                }
            }
        }
    });
}

// ===== UPDATE HIRING CHART WITH FILTER =====
function updateHiringChart(monthsCount) {
    initHiringChart(monthsCount);
    
    // Update active button
    document.querySelectorAll('#hiringFilters .filter-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.target.classList.add('active');
}

// ===== UPDATE TOP JOBS CHART WITH FILTER =====
function updateTopJobsChart(limit) {
    initTopJobsChart(limit);
    
    // Update active button
    document.querySelectorAll('#topJobsFilters .filter-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.target.classList.add('active');
}

// ===== INITIALIZE ON PAGE LOAD =====
document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 Dashboard loaded');
    
    // Small delay to ensure DOM is ready
    setTimeout(() => {
        try {
            initHiringChart(12);
            initTopJobsChart(5);
            console.log('✅ Charts initialized successfully');
        } catch (error) {
            console.error('❌ Chart initialization error:', error);
        }
    }, 100);
});

// ===== HANDLE WINDOW RESIZE =====
let resizeTimer;
window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
        // Reinitialize charts on resize
        initHiringChart(12);
        initTopJobsChart(5);
    }, 250);
});
</script>