<!DOCTYPE html>
<html>
<head>
    <title>Login - AI Fit Index</title>
    <style>
        /* ===== LOGIN PAGE STYLES - PURE APPLE ===== */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: #f5f5f7;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 400px;
            width: 100%;
            background: #ffffff;
            padding: 40px 35px;
            border-radius: 28px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            border: 1px solid #e5e5e5;
        }

        h1 { 
            font-size: 28px; 
            font-weight: 600; 
            margin-bottom: 6px; 
            color: #1d1d1f; 
            letter-spacing: -0.01em;
        }

        .subtitle { 
            color: #86868b; 
            font-size: 15px; 
            margin-bottom: 32px; 
            font-weight: 400;
        }

        /* Tabs */
        .tab-container {
            display: flex;
            gap: 24px;
            border-bottom: 1px solid #e5e5e5;
            margin-bottom: 28px;
        }

        .tab {
            padding-bottom: 12px;
            text-decoration: none;
            color: #86868b;
            font-weight: 500;
            font-size: 16px;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
            cursor: pointer;
            background: none;
            border: none;
        }

        .tab.active {
            color: #1d1d1f;
            border-bottom-color: #1d1d1f;
        }

        /* Forms */
        .form { 
            display: none; 
        }

        .form.active { 
            display: block; 
        }

        .form-group { 
            margin-bottom: 22px; 
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 500;
            color: #1d1d1f;
        }

        input, select {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid #d2d2d7;
            border-radius: 14px;
            font-size: 15px;
            transition: all 0.2s;
            background: #ffffff;
            color: #1d1d1f;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #1d1d1f;
            box-shadow: 0 0 0 3px rgba(0,0,0,0.02);
        }

        input::placeholder {
            color: #a1a1a6;
            font-size: 15px;
        }

        .btn {
            width: 100%;
            padding: 14px;
            background: #1d1d1f;
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            margin: 10px 0 18px;
        }

        .btn:hover { 
            background: #2d2d2f; 
        }

        .link {
            text-align: center;
            color: #86868b;
            font-size: 14px;
        }

        .link a {
            color: #1d1d1f;
            text-decoration: none;
            font-weight: 500;
            cursor: pointer;
            background: none;
            border: none;
            font-size: 14px;
        }

        .link a:hover { 
            text-decoration: underline; 
        }

        /* Messages */
        .error {
            background: #fee2e2;
            color: #dc2626;
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 24px;
            font-size: 14px;
            border-left: 4px solid #dc2626;
        }

        .success {
            background: #e6f7e6;
            color: #0e6245;
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 24px;
            font-size: 14px;
            border-left: 4px solid #0e6245;
        }

        hr {
            border: none;
            border-top: 1px solid #e5e5e5;
            margin: 24px 0 16px;
        }

        /* Select dropdown */
        select {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 16px center;
            background-size: 16px;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .container {
                padding: 30px 20px;
            }
            
            h1 {
                font-size: 26px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>AI Fit Index</h1>
        <div class="subtitle">Intelligent recruitment platform</div>

        <!-- Messages -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success"><%= success %></div>
        <% } %>

        <!-- Tabs -->
        <div class="tab-container">
            <a href="/" class="tab <%= (typeof tab === 'undefined' || tab === 'login') ? 'active' : '' %>">Sign In</a>
            <a href="/?tab=register" class="tab <%= (typeof tab !== 'undefined' && tab === 'register') ? 'active' : '' %>">Sign Up</a>
        </div>

        <!-- Login Form -->
        <% if (typeof tab === 'undefined' || tab === 'login') { %>
            <div class="form active">
                <form method="POST" action="/api/auth/login">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="Enter your email" required>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="Enter your password" required>
                    </div>
                    <button type="submit" class="btn">Sign In</button>
                </form>
                <div class="link">
                    <a href="/?tab=forgot">Forgot password?</a>
                </div>
            </div>
        <% } %>

        <!-- Register Form -->
        <% if (typeof tab !== 'undefined' && tab === 'register') { %>
            <div class="form active">
                <form method="POST" action="/api/auth/register">
                    <div class="form-group">
                        <label>Full name</label>
                        <input type="text" name="name" placeholder="Enter your name" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="Enter your email" required>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="Min 6 characters" required minlength="6">
                    </div>
                    <div class="form-group">
                        <label>Role</label>
                        <select name="role" required>
                            <option value="">Select role</option>
                            <option value="candidate">Candidate</option>
                            <option value="hr">HR / Recruiter</option>
                        </select>
                    </div>
                    <button type="submit" class="btn">Create Account</button>
                </form>
                <hr>
                <div class="link">
                    Already have an account? <a href="/">Sign in</a>
                </div>
            </div>
        <% } %>

        <!-- Forgot Password Form -->
        <% if (typeof tab !== 'undefined' && tab === 'forgot') { %>
            <div class="form active">
                <form method="POST" action="/api/auth/forgot-password">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="Enter your registered email" required>
                    </div>
                    <button type="submit" class="btn">Send Reset Link</button>
                </form>
                <hr>
                <div class="link">
                    <a href="/">← Back to Sign In</a>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>