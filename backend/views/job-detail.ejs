<h2><%= job.title %></h2>

<div style="margin-bottom:20px;">
  <p><strong>Required Skills:</strong> <%= job.requiredSkills.join(", ") %></p>
  <p><strong>Minimum Experience:</strong> <%= job.minExperience %> years</p>
</div>

<hr>

<h3>🏆 AI Top 3 Candidates</h3>

<% if (applications.length > 0) { %>
  <% applications.slice(0,3).forEach((app, index) => { %>
    <div style="margin-bottom:5px;">
      Rank <strong><%= index + 1 %></strong> :
      <strong><%= app.candidate?.name || "Unknown" %></strong>
      (Score: <%= app.evaluation?.finalScore || 0 %>)
    </div>
  <% }) %>
<% } else { %>
  <p>No applicants yet.</p>
<% } %>

<hr>

<h3>Applicants</h3>

<input type="text" id="searchInput" 
       placeholder="Search candidate..." 
       style="padding:6px; width:250px; margin-bottom:10px;"
       onkeyup="filterCandidates()">

<form method="POST" action="/hr/compare/<%= job._id %>">

<table border="1" cellpadding="8" width="100%" id="candidateTable">
<tr style="background:#f5f5f5;">
  <th>Select</th>
  <th>Name</th>
  <th>Final Score</th>
  <th>Skill</th>
  <th>Experience</th>
  <th>Confidence</th>
</tr>

<% applications.forEach(app => { %>
<tr>
  <td>
    <input type="checkbox" name="candidates" value="<%= app.candidate.toString() %>">
  </td>

  <td><%= app.candidateName %></td>

  <td><%= app.evaluation?.finalScore || 0 %></td>

  <td><%= app.evaluation?.skillScore || 0 %></td>

  <td><%= app.evaluation?.experienceScore || 0 %></td>

  <td><%= app.evaluation?.confidenceIndex || 0 %></td>
</tr>
<% }) %>

</table>

<br>
<button type="submit" style="
  background:#2563eb;
  color:white;
  border:none;
  padding:8px 16px;
  border-radius:4px;
  cursor:pointer;
">
  Compare Selected
</button>

</form>

<script>
function filterCandidates() {
  const input = document.getElementById("searchInput").value.toLowerCase();
  const rows = document.querySelectorAll("#candidateTable tr");

  rows.forEach((row, index) => {
    if (index === 0) return;

    const name = row.cells[1].innerText.toLowerCase();
    row.style.display = name.includes(input) ? "" : "none";
  });
}
</script>