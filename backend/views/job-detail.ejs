<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<%
currentPage = 'dashboard';
%>

<div class="job-detail-header">
    <div>
        <h2><%= job.title %></h2>
        <div class="job-meta">
            <span class="meta-item"><strong>Required Skills:</strong> <%= job.requiredSkills.join(", ") %></span>
            <span class="meta-item"><strong>Minimum Experience:</strong> <%= job.minExperience %> years</span>
        </div>
    </div>
    <a href="/hr/dashboard" class="back-link">← Back to Dashboard</a>
</div>

<!-- AI Top 3 Candidates -->
<div class="top-candidates">
    <h3>AI Top 3 Candidates</h3>
    <% if (applications.length > 0) { %>
        <div class="top-candidates-list">
            <% applications.slice(0,3).forEach((app, index) => { 
              const candidateName = 
                  (app.candidate && app.candidate.name) ||
                  app.candidateName ||
                  'Unknown';

              const score = app.evaluation && app.evaluation.finalScore 
                  ? app.evaluation.finalScore 
                  : 0;
          %>
              <div class="top-candidate-card">
                  <span class="rank">#<%= index + 1 %></span>
                  <span class="name"><%= candidateName %></span>
                  <span class="score">Score: <%= score %></span>
              </div>
          <% }) %>
        </div>
    <% } else { %>
        <p class="no-data">No applicants yet.</p>
    <% } %>
</div>

<!-- Applicants Section -->
<div class="applicants-section">
    <h3>Applicants</h3>
    
    <!-- Search Box -->
    <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search by name..." class="search-input">
        <span class="search-icon">🔍</span>
    </div>

    <!-- Applicants Table -->
    <div class="table-container">
        <form method="POST" action="/hr/compare/<%= job._id %>" id="compareForm">
            <table class="applicants-table">
                <thead>
                    <tr>
                        <th width="50">Select</th>
                        <th>Name</th>
                        <th>Final Score</th>
                        <th>Skill</th>
                        <th>Experience</th>
                        <th>Confidence</th>
                        <th>Missing Skills</th>
                    </tr>
                </thead>
                <tbody id="applicantsTableBody">
                    <% applications.forEach((app) => { 

                      const candidateName = 
                          (app.candidate && app.candidate.name) ||
                          app.candidateName ||
                          'Unknown';

                      const candidateId = app.candidate && app.candidate._id 
                          ? app.candidate._id 
                          : app.candidate;

                  %>
                      <tr class="applicant-row" data-name="<%= candidateName.toLowerCase() %>">
                          <td>
                              <input type="checkbox" 
                                    name="applications" 
                                    value="<%= app._id %>"
                                    class="candidate-checkbox">
                          </td>

                          <td>
                              <div class="name-with-avatar">
                                  <span class="avatar">
                                      <%= candidateName ? candidateName.charAt(0).toUpperCase() : 'U' %>
                                  </span>
                                  <%= candidateName %>
                              </div>
                          </td>

                          <td><%= app.evaluation?.finalScore || 0 %></td>
                          <td><%= app.evaluation?.skillScore || 0 %></td>
                          <td><%= app.evaluation?.experienceScore || 0 %></td>
                          <td><%= app.evaluation?.confidenceIndex || 0 %></td>

                          <td>
                          <% if(app.evaluation?.missingSkills?.length > 0){ %>
                              <span style="color:red">
                                  <%= app.evaluation.missingSkills.join(", ") %>
                              </span>
                         <% } else { %>
                            Perfect Match
                         <% } %>

                        </td>
                      </tr>
                  <% }) %>
                </tbody>
            </table>
            
            <!-- Compare Button - INSIDE FORM -->
            <div class="compare-action">
                <button type="submit" class="btn-compare" id="compareBtn" disabled>
                    Compare Selected (0)
                </button>
                <p class="hint">Select exactly 2 candidates to compare</p>
            </div>
        </form>
    </div>
    <div class="ranking-chart-container">

    <h3>AI Candidate Ranking</h3>

    <div class="chart-wrapper">
    <canvas id="rankingChart"></canvas>
    </div>

    </div>
</div>

<style>
.job-detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.job-detail-header h2 {
    font-size: 1.8rem;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: 10px;
}

.job-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    color: #86868b;
}

.meta-item {
    font-size: 0.95rem;
}

.meta-item strong {
    color: #1d1d1f;
}

.back-link {
    color: #1d1d1f;
    text-decoration: none;
    font-weight: 500;
    padding: 8px 16px;
    background: #f5f5f7;
    border-radius: 12px;
    transition: all 0.2s;
}

.back-link:hover {
    background: #e5e5e5;
}

.top-candidates {
    background: white;
    border-radius: 24px;
    padding: 24px;
    margin-bottom: 30px;
    border: 1px solid #e5e5e5;
}

.top-candidates h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: 20px;
}

.top-candidates-list {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
}

.top-candidate-card {
    background: #f5f5f7;
    padding: 12px 20px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 200px;
}

.rank {
    background: #1d1d1f;
    color: white;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
}

.ranking-chart-container{
margin-top:40px;
background:white;
padding:20px;
border-radius:20px;
border:1px solid #e5e5e5;
}

.chart-wrapper{
width:100%;
height:350px;
}

.name {
    font-weight: 500;
    color: #1d1d1f;
    flex: 1;
}

.score {
    color: #86868b;
    font-size: 0.9rem;
}

.search-box {
    position: relative;
    margin-bottom: 24px;
    max-width: 400px;
}

.search-input {
    width: 100%;
    padding: 14px 20px 14px 45px;
    border: 1px solid #d2d2d7;
    border-radius: 16px;
    font-size: 0.95rem;
    transition: all 0.2s;
    background: white;
}

.search-input:focus {
    outline: none;
    border-color: #1d1d1f;
    box-shadow: 0 0 0 3px rgba(0,0,0,0.02);
}

.search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #86868b;
}

.table-container {
    background: white;
    border-radius: 24px;
    border: 1px solid #e5e5e5;
    overflow-x: auto;
    margin-bottom: 20px;
    padding: 20px;
}

.applicants-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
}

.applicants-table th {
    text-align: left;
    padding: 18px 16px;
    background: #f5f5f7;
    font-weight: 500;
    color: #1d1d1f;
    font-size: 0.9rem;
    border-bottom: 1px solid #e5e5e5;
}

.applicants-table td {
    padding: 16px;
    border-bottom: 1px solid #f5f5f7;
    color: #1d1d1f;
}

.applicants-table tr:hover {
    background: #fafafc;
}

.name-with-avatar {
    display: flex;
    align-items: center;
    gap: 10px;
}

.avatar {
    width: 32px;
    height: 32px;
    background: #1d1d1f;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 500;
}

.candidate-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
}

.compare-action {
    text-align: right;
    padding: 20px 0 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 20px;
}

.btn-compare {
    background: #1d1d1f;
    color: white;
    border: none;
    padding: 14px 32px;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-compare:hover:not(:disabled) {
    background: #2d2d2f;
}

.btn-compare:disabled {
    background: #e5e5e5;
    color: #86868b;
    cursor: not-allowed;
}

.hint {
    color: #86868b;
    font-size: 0.85rem;
    margin-top: 8px;
}

.no-data {
    color: #86868b;
    font-style: italic;
    padding: 20px;
    text-align: center;
    background: #f5f5f7;
    border-radius: 16px;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const searchInput = document.getElementById("searchInput");
    const rows = document.querySelectorAll(".applicant-row");
    const checkboxes = document.querySelectorAll(".candidate-checkbox");
    const compareBtn = document.getElementById("compareBtn");
    const compareForm = document.getElementById("compareForm");

    // ===== SEARCH =====
    if (searchInput) {
        searchInput.addEventListener("input", function (e) {
            const searchTerm = e.target.value.toLowerCase();

            rows.forEach(row => {
                const name = row.dataset.name || "";
                row.style.display = name.includes(searchTerm) ? "" : "none";
            });
        });
    }

    // ===== UPDATE BUTTON STATE =====
    function updateCompareButton() {
        const selected = document.querySelectorAll(".candidate-checkbox:checked");
        const count = selected.length;

        compareBtn.textContent = `Compare Selected (${count})`;

        if (count === 2) {
            compareBtn.disabled = false;
        } else {
            compareBtn.disabled = true;
        }
    }

    // ===== LIMIT SELECTION TO 2 =====
    checkboxes.forEach(cb => {
        cb.addEventListener("change", function () {

            const selected = document.querySelectorAll(".candidate-checkbox:checked");

            if (selected.length > 2) {
                this.checked = false;
                alert("You can only select exactly 2 candidates.");
                return;
            }

            updateCompareButton();
        });
    });

    // ===== FORM SUBMIT SAFETY CHECK =====
    if (compareForm) {
        compareForm.addEventListener("submit", function (e) {
            const selected = document.querySelectorAll(".candidate-checkbox:checked");

            if (selected.length !== 2) {
                e.preventDefault();
                alert("Please select exactly 2 candidates to compare.");
            }
        });
    }

    // Initialize
    updateCompareButton();
});
</script>

<script>

const candidates = [
<% applications.forEach(app => { %>
{
name: "<%= app.candidateName %>",
score: <%= app.evaluation?.finalScore || 0 %>
},
<% }) %>
]

const labels = candidates.map(c => c.name)
const scores = candidates.map(c => c.score)

new Chart(document.getElementById("rankingChart"), {

type: "bar",

data: {
labels: labels,
datasets: [{
label: "AI Fit Score",
data: scores,
backgroundColor: "#6aa7d8"
}]
},

options:{
responsive:true,
maintainAspectRatio:false,
scales:{
y:{
beginAtZero:true,
max:100
}
}
}

})

</script>